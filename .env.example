# ===== NutriChefIA - Variables de entorno =====
# Copia este archivo a ".env" y completa los valores reales.

# Puerto del servidor (3002 en local para no chocar con MedicaIA:3000 ni NutriIA:3001)
PORT=3002

# Clave secreta para firmar los tokens JWT (cambiala por una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_larga_y_secreta

# ===== Proveedor de IA =====
# Fallback si la BD no tiene ai_modo: "gemini" | "claude" | "ambos".
# En runtime manda la config del admin (ai_modo / ai_prioridad).
AI_PROVIDER=gemini

# --- Gemini (Google) ---
# OJO: si reusas la key de NutriIA/MedicaIA, el credito de Gemini es COMPARTIDO
# entre las apps. Este planificador consume mucho mas que un escaner.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Claude (Anthropic) ---
# API oficial o un gateway compatible (define ANTHROPIC_BASE_URL solo si usas gateway).
# OJO con el gateway aiprimetech: el "grupo" de la API key (Claude Default 0.85x /
# Fast 1.1x / Max 1.3x) es un MULTIPLICADOR DE PRECIO, no un modelo. Los tres grupos
# sirven los mismos modelos: opus-4-8, opus-4-6, sonnet-5 y fable-5. El modelo se elige
# AQUI, no alla.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://aiprimetech.io
ANTHROPIC_MODEL=claude-sonnet-5

# ===== Datos del negocio (Yape) =====
YAPE_NUMERO=999888777
YAPE_TITULAR=NutriChefIA Peru
# Precio del plan Premium en soles
PRECIO_PREMIUM=19.90

# ===== Cuenta admin inicial (se crea con npm run seed) =====
ADMIN_EMAIL=admin@nutrichefia.pe
ADMIN_PASSWORD=admin123
ADMIN_NOMBRE=Administrador

# Analisis de producto gratuitos para nuevos usuarios (plan Free)
ANALISIS_FREE=3
