{
  "name": "nutrichefia",
  "version": "1.0.0",
  "description": "NutriChefIA - Planificador de comidas familiares con IA: escanea productos y arma el menu semanal segun tu despensa, tu familia y tu region (mercado peruano)",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch-path=src src/server.js",
