    "smoke": "node pruebas/smoke-hogar-despensa.js",
    "smoke:platos": "node pruebas/smoke-platos.js",
    "smoke:plan": "node pruebas/smoke-plan.js"
  },
  "keywords": [
    "nutricion",
    "recetas",
    "menu-semanal",
    "ia",
    "peru"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@google/genai": "^2.9.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "jsdom": "^28.0.2"
  }
